<Window x:Class="TomatoNoteTimer.Dialogs.HotkeySettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷键设置"
        Height="480"
        Width="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="13"
                   TextWrapping="Wrap">
            请点击对应输入框后按下组合键（示例：Ctrl+Alt+S）。
            <LineBreak />
            默认不设置快捷键；可使用清空按钮移除单项绑定。
        </TextBlock>

        <Border Grid.Row="1"
                Margin="0,10,0,10"
                Padding="10"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,7,8,7"
                           VerticalAlignment="Center"
                           Text="开启倒计时" />
                <TextBox x:Name="StartTimerTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,4"
                         Padding="6,4"
                         IsReadOnly="True"
                         Tag="StartTimer"
                         GotKeyboardFocus="HotkeyInput_GotKeyboardFocus"
                         PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                         PreviewTextInput="HotkeyInput_PreviewTextInput" />
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Margin="10,4,0,4"
                        Padding="10,2"
                        Tag="StartTimer"
                        Content="清空"
                        Click="ClearItem_Click" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,7,8,7"
                           VerticalAlignment="Center"
                           Text="暂停倒计时" />
                <TextBox x:Name="PauseTimerTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,4"
                         Padding="6,4"
                         IsReadOnly="True"
                         Tag="PauseTimer"
                         GotKeyboardFocus="HotkeyInput_GotKeyboardFocus"
                         PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                         PreviewTextInput="HotkeyInput_PreviewTextInput" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Margin="10,4,0,4"
                        Padding="10,2"
                        Tag="PauseTimer"
                        Content="清空"
                        Click="ClearItem_Click" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,7,8,7"
                           VerticalAlignment="Center"
                           Text="重置倒计时" />
                <TextBox x:Name="ResetTimerTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,4"
                         Padding="6,4"
                         IsReadOnly="True"
                         Tag="ResetTimer"
                         GotKeyboardFocus="HotkeyInput_GotKeyboardFocus"
                         PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                         PreviewTextInput="HotkeyInput_PreviewTextInput" />
                <Button Grid.Row="2"
                        Grid.Column="2"
                        Margin="10,4,0,4"
                        Padding="10,2"
                        Tag="ResetTimer"
                        Content="清空"
                        Click="ClearItem_Click" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,7,8,7"
                           VerticalAlignment="Center"
                           Text="进入/退出简洁模式" />
                <TextBox x:Name="ToggleSimpleModeTextBox"
                         Grid.Row="3"
                         Grid.Column="1"
                         Margin="0,4"
                         Padding="6,4"
                         IsReadOnly="True"
                         Tag="ToggleSimpleMode"
                         GotKeyboardFocus="HotkeyInput_GotKeyboardFocus"
                         PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                         PreviewTextInput="HotkeyInput_PreviewTextInput" />
                <Button Grid.Row="3"
                        Grid.Column="2"
                        Margin="10,4,0,4"
                        Padding="10,2"
                        Tag="ToggleSimpleMode"
                        Content="清空"
                        Click="ClearItem_Click" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,7,8,7"
                           VerticalAlignment="Center"
                           Text="窗口置顶开关" />
                <TextBox x:Name="ToggleTopMostTextBox"
                         Grid.Row="4"
                         Grid.Column="1"
                         Margin="0,4"
                         Padding="6,4"
                         IsReadOnly="True"
                         Tag="ToggleTopMost"
                         GotKeyboardFocus="HotkeyInput_GotKeyboardFocus"
                         PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                         PreviewTextInput="HotkeyInput_PreviewTextInput" />
                <Button Grid.Row="4"
                        Grid.Column="2"
                        Margin="10,4,0,4"
                        Padding="10,2"
                        Tag="ToggleTopMost"
                        Content="清空"
                        Click="ClearItem_Click" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,7,8,7"
                           VerticalAlignment="Center"
                           Text="窗口固定开关" />
                <TextBox x:Name="ToggleFixedModeTextBox"
                         Grid.Row="5"
                         Grid.Column="1"
                         Margin="0,4"
                         Padding="6,4"
                         IsReadOnly="True"
                         Tag="ToggleFixedMode"
                         GotKeyboardFocus="HotkeyInput_GotKeyboardFocus"
                         PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                         PreviewTextInput="HotkeyInput_PreviewTextInput" />
                <Button Grid.Row="5"
                        Grid.Column="2"
                        Margin="10,4,0,4"
                        Padding="10,2"
                        Tag="ToggleFixedMode"
                        Content="清空"
                        Click="ClearItem_Click" />
            </Grid>
        </Border>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,0,0,8"
                   Foreground="#CC1A1A1A"
                   Text="提示：先点击输入框，再按组合键。"
                   TextWrapping="Wrap" />

        <DockPanel Grid.Row="3">
            <Button Width="92"
                    Padding="0,4"
                    Content="清空全部"
                    Click="ClearAll_Click" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <Button Width="88"
                        Margin="0,0,8,0"
                        Padding="0,4"
                        Content="取消"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button Width="88"
                        Padding="0,4"
                        Content="保存"
                        IsDefault="True"
                        Click="Save_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
