<Window x:Class="TomatoNoteTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="番茄钟便签"
        Width="380"
        Height="210"
        MinWidth="140"
        MinHeight="88"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        MouseWheel="Window_MouseWheel"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing">
    <Border x:Name="RootBorder"
            Margin="1"
            CornerRadius="9"
            Background="Transparent"
            BorderThickness="0"
            BorderBrush="Transparent"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="0"
                              Opacity="0.24"
                              Color="#7F000000" />
        </Border.Effect>
        <Grid>
            <Border x:Name="PanelBackground"
                    CornerRadius="9"
                    BorderThickness="1"
                    Background="#8C4C6D8C"
                    BorderBrush="#77FFFFFF" />

            <Border x:Name="AppleEdgeOverlay"
                    CornerRadius="9"
                    Visibility="Collapsed"
                    IsHitTestVisible="False" />

            <Border x:Name="MaterialOverlay"
                    CornerRadius="9"
                    Visibility="Collapsed"
                    IsHitTestVisible="False" />

            <TextBlock x:Name="NotesDisplayText"
                       Text="在这里记录你的任务..."
                       Foreground="#FFF4F4F4"
                       TextWrapping="Wrap"
                       VerticalAlignment="Stretch"
                       HorizontalAlignment="Stretch"
                       Margin="8,8,8,44"
                       FontSize="18"
                       FontFamily="Microsoft YaHei UI" />

            <TextBlock x:Name="CountdownText"
                       Text="25:00"
                       Foreground="#FFFFFFFF"
                       FontWeight="SemiBold"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,4" />
        </Grid>
    </Border>
</Window>
